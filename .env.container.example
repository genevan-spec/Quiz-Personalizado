# .env.container.example — Variáveis de produção para containers
# Copia para .env.container e preenche TODOS os valores marcados com <PREENCHER>
# NUNCA commitar o .env.container com valores reais

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=quiz_db
POSTGRES_USER=quiz_user
POSTGRES_PASSWORD=<PREENCHER_password_forte>

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# URL da BD (o host 'db' é o nome do serviço no podman-compose)
DATABASE_URL=postgresql://quiz_user:<PREENCHER_password_forte>@db:5432/quiz_db?schema=public

# ── CORS ──────────────────────────────────────────────────────────────────────
# Porta exposta pelo serviço frontend (ver FRONTEND_PORT abaixo)
CORS_ORIGIN=http://localhost:8080

# ── JWT RS256 — chaves em Base64 ──────────────────────────────────────────────
# Geração (uma vez): node scripts/generate-keys.js
# Depois:
#   JWT_PRIVATE_KEY_B64=$(base64 -w0 < apps/backend/keys/private.pem)
#   JWT_PUBLIC_KEY_B64=$(base64 -w0  < apps/backend/keys/public.pem)
# O scripts/start.sh faz isto automaticamente se as chaves existirem.
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=8080

# ── Seed (opcional) ───────────────────────────────────────────────────────────
# Definir como true na PRIMEIRA execução para popular a base de dados
# Voltar a false depois para não re-popular em restarts
SEED_DB=false
