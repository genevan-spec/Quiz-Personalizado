# Backend — Variáveis de Ambiente
# Copia este ficheiro para .env e preenche os valores

# ── Base de dados ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://quiz_user:quiz_pass@localhost:5432/quiz_db?schema=public"

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Opção 1 (desenvolvimento): usa os ficheiros apps/backend/keys/private.pem e public.pem
#   → Corre: node scripts/generate-keys.js
#
# Opção 2 (produção / containers): variáveis de ambiente em Base64
#   JWT_PRIVATE_KEY_B64=<base64 da chave privada PEM>
#   JWT_PUBLIC_KEY_B64=<base64 da chave pública PEM>
