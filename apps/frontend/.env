# Variáveis de ambiente — Fase 1
# Vite expõe apenas variáveis com prefixo VITE_ ao cliente

VITE_APP_NAME="Quiz Personalizado"
VITE_APP_VERSION="1.0.0"

# URL base da API (será usado nas fases seguintes com o backend)
VITE_API_BASE_URL=http://localhost:3000/api

# Número máximo de perguntas por quiz
VITE_MAX_QUESTIONS=20
